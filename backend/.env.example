# Hostinger MySQL (hPanel → Veritabanları → MySQL)
# Örnek: mysql://KULLANICI:SIFRE@HOST:3306/VERITABANI
# SSL gerekiyorsa: ...?sslaccept=strict
DATABASE_URL="mysql://ecommerce:ecommerce@127.0.0.1:3306/ecommerce"

JWT_SECRET=
JWT_REFRESH_SECRET=

# Hostinger'da Redis yok: true yapın (ödeme reconcile cron devre dışı)
REDIS_DISABLED=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

PORT=3000

# Admin panel / mobil için CORS (virgülle ayırın)
# CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com
